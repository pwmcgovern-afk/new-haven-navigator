generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Resource {
  id          String   @id @default(uuid())
  name        String
  organization String?
  description String

  // Categories (stored as array)
  categories  String[]

  // Location
  address     String?
  city        String   @default("New Haven")
  state       String   @default("CT")
  zip         String?
  latitude    Float?
  longitude   Float?

  // Contact
  phone       String?
  website     String?
  email       String?
  hours       String?

  // Eligibility criteria (JSON for flexibility)
  eligibility Json?

  // Application info
  howToApply  String?

  // Organization-specific tips
  tips        String[]

  // Spanish translations
  nameEs        String?
  descriptionEs String?
  howToApplyEs  String?
  tipsEs        String[]

  // Data source tracking
  source      String   @default("manual")
  sourceId    String?

  // Full-text search (managed by DB trigger)
  search_vector Unsupported("tsvector")?

  // Timestamps
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categories])
  @@index([city])
  @@index([source])
}

model Category {
  id           String @id @default(uuid())
  name         String
  slug         String @unique
  description  String?
  icon         String?
  displayOrder Int    @default(0)
}

model Feedback {
  id         String   @id @default(uuid())
  resourceId String
  helpful    Boolean
  createdAt  DateTime @default(now())

  @@index([resourceId])
}

model AnonymousUser {
  id        String         @id @default(uuid())
  token     String         @unique
  createdAt DateTime       @default(now())
  entries   TrackerEntry[]
}

model TrackerEntry {
  id               String   @id @default(uuid())
  userId           String
  resourceId       String
  resourceName     String
  resourceNameEs   String?
  organizationName String?
  status           String   @default("reached_out")
  contactPerson    String   @default("")
  dateContacted    String   @default("")
  notes            String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  user AnonymousUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceId])
}

model ChangeLog {
  id           String   @id @default(uuid())
  resourceId   String
  resourceName String
  action       String   // "created", "updated", "deleted", "verified"
  changes      Json?    // { field: { from: old, to: new } }
  createdAt    DateTime @default(now())

  @@index([resourceId])
  @@index([createdAt(sort: Desc)])
}

model PageView {
  id         String   @id @default(uuid())
  path       String
  resourceId String?
  category   String?
  createdAt  DateTime @default(now())

  @@index([path])
  @@index([resourceId])
  @@index([createdAt(sort: Desc)])
}
