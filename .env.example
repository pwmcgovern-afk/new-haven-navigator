# Database connection string
DATABASE_URL="postgresql://user:password@host:5432/database"
DIRECT_URL="postgresql://user:password@host:5432/database"

# Anthropic API key for AI chat assistant
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Admin dashboard API key (generate with: openssl rand -hex 32)
ADMIN_API_KEY="your-admin-api-key"

# 211 Connecticut API key (register at https://register.211.org/)
API_211_KEY="your-211-api-key"

# Vercel cron secret (auto-set by Vercel, or generate with: openssl rand -hex 32)
CRON_SECRET="your-cron-secret"
